<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_office_alpaca" targetNamespace="http://camunda.org/workshop/alpaca" exporter="Camunda Web Modeler" exporterVersion="1d3193f" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:process id="Process_rw0nf3v" name="Office Alpaca Approval" isExecutable="true">
    <bpmn:startEvent id="StartEvent_Submitted" name="Alpaca request submitted">
      <bpmn:outgoing>Flow_Start_Upload</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_UploadDocuments" name="Upload request documents">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition candidateGroups="alpaca-requesters" />
        <zeebe:formDefinition formId="Form_gkssnth" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Start_Upload</bpmn:incoming>
      <bpmn:incoming>Flow_MissingInfo_Upload</bpmn:incoming>
      <bpmn:outgoing>Flow_1c4m6hv</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:businessRuleTask id="Task_ValidateDocuments" name="Validate extracted data">
      <bpmn:extensionElements>
        <zeebe:calledDecision decisionId="document-validity" resultVariable="documentsValid" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1apshbp</bpmn:incoming>
      <bpmn:outgoing>Flow_Validate_Gateway</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:exclusiveGateway id="Gateway_DocumentsValid" name="Documents valid?" default="Flow_Docs_Invalid">
      <bpmn:incoming>Flow_Validate_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Docs_Invalid</bpmn:outgoing>
      <bpmn:outgoing>Flow_Docs_Valid</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_RequestMissingInfo" name="Request missing information">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition candidateGroups="alpaca-requesters" />
        <zeebe:formDefinition formId="Form_3yhhwj9" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Docs_Invalid</bpmn:incoming>
      <bpmn:outgoing>Flow_MissingInfo_Upload</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_CheckOfficeReadiness" name="Check office readiness">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="check-office-readiness" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Docs_Valid</bpmn:incoming>
      <bpmn:outgoing>Flow_OfficeReady_Join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_AnyBlockers" name="Any blocker found?" default="Flow_NoBlockers">
      <bpmn:incoming>Flow_OfficeReady_Join</bpmn:incoming>
      <bpmn:outgoing>Flow_Blockers_Reject</bpmn:outgoing>
      <bpmn:outgoing>Flow_NoBlockers</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:adHocSubProcess id="SubProcess_AgentPlan" name="Propose alpaca event plan" zeebe:modelerTemplate="io.camunda.connectors.agenticai.aiagent.jobworker.v1" zeebe:modelerTemplateVersion="6" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda.agenticai:aiagent-job-worker:1" retries="3" />
        <zeebe:adHoc outputCollection="toolCallResults" outputElement="={&#10;  id: toolCall._meta.id,&#10;  name: toolCall._meta.name,&#10;  content: toolCallResult&#10;}" />
        <zeebe:ioMapping>
          <zeebe:input source="openai" target="provider.type" />
          <zeebe:input source="{{secrets.OPENAI_API_KEY}}" target="provider.openai.authentication.apiKey" />
          <zeebe:input source="gpt-5.4-mini" target="provider.openai.model.model" />
          <zeebe:input source="0.2" target="provider.openai.model.parameters.temperature" />
          <zeebe:input source="=&#34;You are the Office Alpaca Event Planner. Propose a safe, funny-but-professional alpaca event plan for a one-day office visit. Use the provided tools when you need office policy or past visit history to make a profound suggestion. &#10;If you become aware of any new requirements to conduct an alpaca visit you MUST ensure these requirements are met. &#10;&#10;────────────────────────────────&#10;# Mandatory tool use&#10;────────────────────────────────&#10;For every request you MUST inspect the provided tools and evaluate which tool would be the next step to achieve your goal.&#10;&#10;────────────────────────────────&#10;# CHAIN-OF-THOUGHT FORMAT&#10;────────────────────────────────&#10;Wrap minimal, inspectable reasoning in this XML template:&#10;&#10;&#60;thinking&#62;&#10;  &#60;context&#62;…briefly state the alpaca visit request and current state of the process&#60;/context&#62;&#10;  &#60;reflection&#62;…list candidate tools (by capability and actual names from the list), justify which you will call next and why; justify why not the others…&#60;/reflection&#62;&#10;&#60;/thinking&#62;&#10;&#10;Final Output: JSON with fields proposedSchedule (array of {time, activity}), riskNotes (string), recommendedDecision (APPROVE|REVIEW). Never override safety or budget rules.&#34;" target="data.systemPrompt.prompt" />
          <zeebe:input source="=allExtractedData" target="data.userPrompt.prompt" />
          <zeebe:input target="agentContext" />
          <zeebe:input source="in-process" target="data.memory.storage.type" />
          <zeebe:input source="20" target="data.memory.contextWindowSize" />
          <zeebe:input source="6" target="data.limits.maxModelCalls" />
          <zeebe:input source="WAIT_FOR_TOOL_CALL_RESULTS" target="data.events.behavior" />
          <zeebe:input source="text" target="data.response.format.type" />
          <zeebe:input source="=false" target="data.response.format.parseJson" />
          <zeebe:input source="=true" target="data.response.includeAssistantMessage" />
          <zeebe:input source="=true" target="data.response.includeAgentContext" />
          <zeebe:output source="=agent" target="agent" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="6" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.agenticai.aiagent.jobworker.v1" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_NoBlockers</bpmn:incoming>
      <bpmn:outgoing>Flow_Agent_CAO</bpmn:outgoing>
      <bpmn:scriptTask id="Tool_GetOfficePolicy" name="Get office policy">
        <bpmn:documentation>Returns the office policy for alpaca visits at a given office location. Use when the system prompt or user request needs policy detail (e.g., elevator restrictions, allowed floors, soft-hoof rules).</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:script expression="={&#10;            location: allExtractedData.officeLocation,&#10;            elevatorAllowed: false,&#10;            softHoofMatsRequired: true,&#10;            maxAlpacasPerFloor: 1,&#10;            policyVersion: &#34;2026.05&#34;&#10;          }" resultVariable="toolCallResult" />
        </bpmn:extensionElements>
      </bpmn:scriptTask>
      <bpmn:scriptTask id="Tool_GetPastVisits" name="Get past visit history">
        <bpmn:documentation>Returns a short summary of previous alpaca visits at the requested office.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:script expression="={&#10;            location: allExtractedData.officeLocation, &#10;            pastVisits: [&#10;              {date: &#34;2025-11-04&#34;, outcome: &#34;success&#34;, notes: &#34;Three teams photographed, no incidents.&#34;},&#10;              {date: &#34;2025-06-12&#34;, outcome: &#34;warning&#34;, notes: &#34;Minor carpet incident on level 3.&#34;}&#10;            ]&#10;          }" resultVariable="toolCallResult" />
        </bpmn:extensionElements>
      </bpmn:scriptTask>
    </bpmn:adHocSubProcess>
    <bpmn:exclusiveGateway id="Gateway_CAOApproved" name="CAO approved?" default="Flow_CAO_Reject">
      <bpmn:incoming>Flow_CAO_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_CAO_Approved</bpmn:outgoing>
      <bpmn:outgoing>Flow_CAO_Reject</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_ScheduleVisit" name="Schedule alpaca visit">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="schedule-alpaca-visit" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_CAO_Approved</bpmn:incoming>
      <bpmn:outgoing>Flow_Schedule_Pack</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_Confirmed" name="Alpaca day confirmed">
      <bpmn:incoming>Flow_Schedule_Pack</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_RejectedBlockers" name="Request rejected (blockers)">
      <bpmn:incoming>Flow_Blockers_Reject</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_RejectedCAO" name="Request rejected (CAO)">
      <bpmn:incoming>Flow_CAO_Reject</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_Upload" sourceRef="StartEvent_Submitted" targetRef="Task_UploadDocuments" />
    <bpmn:sequenceFlow id="Flow_Validate_Gateway" sourceRef="Task_ValidateDocuments" targetRef="Gateway_DocumentsValid" />
    <bpmn:sequenceFlow id="Flow_Docs_Invalid" name="missing data" sourceRef="Gateway_DocumentsValid" targetRef="Task_RequestMissingInfo" />
    <bpmn:sequenceFlow id="Flow_MissingInfo_Upload" sourceRef="Task_RequestMissingInfo" targetRef="Task_UploadDocuments" />
    <bpmn:sequenceFlow id="Flow_OfficeReady_Join" sourceRef="Task_CheckOfficeReadiness" targetRef="Gateway_AnyBlockers" />
    <bpmn:sequenceFlow id="Flow_Blockers_Reject" name="blocker" sourceRef="Gateway_AnyBlockers" targetRef="EndEvent_RejectedBlockers">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=officeReady = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_NoBlockers" name="all clear" sourceRef="Gateway_AnyBlockers" targetRef="SubProcess_AgentPlan" />
    <bpmn:sequenceFlow id="Flow_CAO_Approved" name="approved" sourceRef="Gateway_CAOApproved" targetRef="Task_ScheduleVisit">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=caoApproved = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_CAO_Reject" name="rejected" sourceRef="Gateway_CAOApproved" targetRef="EndEvent_RejectedCAO" />
    <bpmn:sequenceFlow id="Flow_Schedule_Pack" sourceRef="Task_ScheduleVisit" targetRef="EndEvent_Confirmed" />
    <bpmn:sequenceFlow id="Flow_1c4m6hv" sourceRef="Task_UploadDocuments" targetRef="Activity_0oc32u3" />
    <bpmn:sequenceFlow id="Flow_1glqysf" sourceRef="Activity_0oc32u3" targetRef="Activity_0otlysh" />
    <bpmn:callActivity id="Activity_0oc32u3" name="Extract Data from Documents">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="=document" target="document" />
          <zeebe:output source="=extractedFields" target="extractedFields" />
        </zeebe:ioMapping>
        <zeebe:calledElement processId="Process_exjzcwi" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1c4m6hv</bpmn:incoming>
      <bpmn:outgoing>Flow_1glqysf</bpmn:outgoing>
      <bpmn:multiInstanceLoopCharacteristics>
        <bpmn:extensionElements>
          <zeebe:loopCharacteristics inputCollection="=alpacaDocuments" inputElement="document" outputCollection="allExtractedFields" outputElement="=extractedFields" />
        </bpmn:extensionElements>
      </bpmn:multiInstanceLoopCharacteristics>
    </bpmn:callActivity>
    <bpmn:sequenceFlow id="Flow_1apshbp" sourceRef="Activity_0otlysh" targetRef="Task_ValidateDocuments" />
    <bpmn:scriptTask id="Activity_0otlysh" name="Flatten extracted data">
      <bpmn:extensionElements>
        <zeebe:script expression="=context merge(allExtractedFields)" resultVariable="allExtractedData" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1glqysf</bpmn:incoming>
      <bpmn:outgoing>Flow_1apshbp</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:sequenceFlow id="Flow_Docs_Valid" name="valid" sourceRef="Gateway_DocumentsValid" targetRef="Task_CheckOfficeReadiness">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=documentsValid.valid = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_CAO_Gateway" sourceRef="Task_CAOReview" targetRef="Gateway_CAOApproved" />
    <bpmn:sequenceFlow id="Flow_Agent_CAO" sourceRef="SubProcess_AgentPlan" targetRef="Task_CAOReview" />
    <bpmn:userTask id="Task_CAOReview" name="Chief Alpaca Officer reviews recommendation">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition candidateGroups="chief-alpaca-officer" />
        <zeebe:ioMapping>
          <zeebe:input source="=from json(agent.responseText)" target="agentResponse" />
        </zeebe:ioMapping>
        <zeebe:formDefinition formId="Form_mokzfmw" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Agent_CAO</bpmn:incoming>
      <bpmn:outgoing>Flow_CAO_Gateway</bpmn:outgoing>
    </bpmn:userTask>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_rw0nf3v">
